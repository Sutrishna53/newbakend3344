{
  "version": 2,
  "functions": {
    "api/*.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/index"
    },
    {
      "source": "/collect",
      "destination": "/api/collect"
    },
    {
      "source": "/send",
      "destination": "/api/send"
    }
  ]
}
